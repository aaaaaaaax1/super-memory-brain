      ],
      "personaIntentTriggers": [
        "你觉得我",
        "我的风格",
        "我的性格",
        "我通常怎么做"
      ]
    },
    "keywordTriggers": [
      "上次",
      "之前",
      "记住",
      "我的偏好",
      "历史",
      "这个项目",
      "继续",
      "还记得",
      "决策",
      "方向",
      "目标",
      "长上下文",
      "大目标",
      "连续失败",
      "越改越偏",
      "经验目录",
      "我的性格",
      "我的经历",
      "我的习惯"
    ],
    "semanticTriggers": [
      "按我的习惯来",
      "照之前方案继续",
      "还是那个项目",
      "接着做",
      "按已有约定",
      "项目有进度但方向不明确",
      "需要保持用户需求",
      "需要保持已接受决策",
      "连续一个大目标推进",
      "先查经验",
      "先按我的偏好来",
      "先想想我是什么风格"
    ],
    "continuationPriority": [
      "visible_context",
      "compression_summary_or_record",
      "active_checkpoint",
      "status-card.json",
      "last-status-snapshot.json",
      "step-ledger.json",
      "recent_tool_results",
      "long_term_memory_as_supplement_only"
    ]
  },
  "adr": {
    "statuses": [
      "proposed",
      "accepted",
      "deprecated",
      "superseded",
      "rejected"
    ],
    "defaultStatus": "accepted",
    "requiredRelations": [
      "decides",
      "has_title",
      "has_status",
      "has_context",
      "has_consequence"
    ],
    "currentStatuses": [
      "proposed",
      "accepted"
    ]
  },
  "expiry": {
    "profileDays": 365,
    "decisionDays": 180,
    "projectDays": 60,
    "taskDays": 14,
    "sessionDays": 3
  },
  "feedback": {
    "negativePatterns": [
      "不是这个",
      "别按上次",
      "不对",
      "错了",
      "以后不要"
    ],
    "negativeTag": "[NEGATIVE_FEEDBACK]"
  },
  "logging": {
    "minimal": true,
    "noRawMemoryInHealth": true,
    "noRawPrivateInLogs": true
  },
  "writeAllowSignals": [
    "记住",
    "以后都",
    "默认",
    "采用",
    "就这个",
    "按这个来",
    "按我的习惯来",
    "我的偏好",
    "我的性格",
    "我的经历",
    "我是一个",
    "我喜欢",
    "我通常",
    "verified",
    "baseline",
    "CURRENT",
    "VERIFIED",
    "DECISION",
    "ADR"
  ],
  "privatePatterns": [
    "api key",
    "apikey",
    "password",
    "passwd",
    "token",
    "cookie",
    "secret",
    "BEGIN PRIVATE KEY",
    "base64,",
    "data:image",
    "Authorization: Bearer",
    "身份证",
    "手机号",
    "住址",
    "银行卡"
  ],
  "maxMemoryChars": 800,
  "admissionThreshold": 3,
  "scores": {
    "explicitRemember": 3,
    "verifiedResult": 2,
    "currentBaseline": 3,
    "decision": 2,
    "adr": 3,
    "reusableWorkflow": 2,
    "temporaryChatPenalty": -3,
    "privateNeedsConfirmation": 0,
    "tooLongPenalty": -2
  },
  "maintenance": {
    "policy": "maintenance-policy.json",
    "postTaskHook": "scripts/post-task-maintenance.ps1",
    "workspaceLifecycle": "scripts/workspace-lifecycle-manager.ps1",
    "autoHygiene": "scripts/auto-hygiene-runner.ps1",
    "selfImprovementQueue": "scripts/self-improvement-queue.ps1",
    "safeLocalHygieneAutomatic": true,
    "confirmationRequiredFor": [
      "external_publish_or_share",
      "private_memory_export",
      "raw_secret_or_private_pattern_body",
      "delete_project_files",
      "broad_overwrite",
      "hook_or_global_startup_rewrite",
      "install_or_hot_refresh",
      "memory_mode_switch",
      "unclear_risk_or_conflict"
    ]
  }
}
