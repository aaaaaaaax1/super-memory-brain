{
  "version": "0.5.73",
  "memoryShortcut": "memory:auto；G1 governs, ORC routes, Sandglass hybrid recall only on semantic/keyword recall; stable state only; private memory requires confirmation and [PRIVACY].",
  "memoryModes": [
    "auto",
    "force",
    "off"
  ],
  "provenanceRequired": [
    "platform",
    "agent",
    "sessionId",
    "taskId",
    "timestamp",
    "status",
    "source",
    "evidence"
  ],
  "checkpointLifecycle": {
    "preExecution": "write active checkpoint before long-running or pre-approved tasks with platform, agent, session/task code, timestamp, current step, and blockers",
    "completion": "clear or supersede the active checkpoint after verification and write a completed state with evidence and next action"
  },
  "preflight": {
    "enabled": true,
    "triggerBeforeCodeChange": true,
    "defaultSilent": true,
    "acceptedConstraintTags": [
      "[CURRENT]",
      "[VERIFIED]",
      "[DECISION]",
      "[ADR]",
      "[TASK]"
    ],
    "acceptedAdrStatuses": [
      "accepted"
    ],
    "maxConstraints": 6,
    "maxClaimChars": 160,
    "guardFailOnConflict": true,
    "writeLastPreflight": true
  },
  "requiredTags": [
    "[CURRENT]",
    "[VERIFIED]",
    "[HISTORY]",
    "[STALE]",
    "[BLOCKER]",
    "[KNOWN_LIMITATION]",
    "[PRIVACY]",
    "[DECISION]",
    "[ADR]",
    "[PROFILE]",
    "[PROJECT]",
    "[TASK]",
    "[SESSION]",
    "[SUMMARY]",
    "[NEGATIVE_FEEDBACK]",
    "[TEAM_TASK]",
    "[COMMANDER]",
    "[DELEGATION]",
    "[EVIDENCE]"
  ],
  "layers": {
    "allowed": [
      "profile",
      "project",
      "decision",
      "task",
      "session"
    ],
    "default": "project",
    "tagMap": {
      "profile": "[PROFILE]",
      "project": "[PROJECT]",
      "decision": "[DECISION]",
      "task": "[TASK]",
      "session": "[SESSION]"
    }
  },
  "teamTasks": {
    "enabled": true,
    "storage": "memory/workspace/team-tasks",
    "index": "memory/workspace/team-task-index.json",
    "defaultSharePolicy": "private_workspace_excluded",
    "dispatchLevels": [
      "direct",
      "single_delegate",
      "team_parallel",
      "review_board"
    ],
    "requiredDelegationFields": [
      "role",
      "task",
      "status",
      "findings",
      "evidence",
      "assumptions",
      "unknowns",
      "risks",
      "recommendation"
    ],
    "memoryAdmission": {
      "allow": [
        "user_approved_rule",
        "verified_fact",
        "accepted_decision",
        "failed_verification_lesson",
        "reusable_workflow"
      ],
      "block": [
        "raw_speculation",
        "unverified_recommendation",
        "message_noise",
        "private_data_without_confirmation",
        "large_raw_log"
      ]
    },
    "codeCapable": {
      "defaultMode": "read-only",
      "requiresCommanderAuthorization": true,
      "requiresAllowedFiles": true,
      "requiresForbiddenFiles": true,
      "requiresVerificationCommands": true,
      "requiresRollback": true,
      "requiresReviewBeforeAcceptance": true,
      "patchApplication": "reserved_not_automatic"
    }
  },
  "retrieval": {
    "top_k": 3,
    "max_tokens": 1200,
    "summaryFirst": true,
    "contextBudget": {
      "enabled": true,
      "profileTokens": 120,
      "checkpointTokens": 160,
      "stateTokens": 220,
      "evidenceTokens": 500,
      "rawFallbackTokens": 160,
      "cardSnippetTokens": 56,
      "maxEvidenceCards": 4,
      "defaultOutput": "evidenceCard"
    },
    "aliasNormalization": {
      "enabled": true,
      "groups": [
        [
          "超级大脑",
          "Super Brain",
          "super-memory-brain",
          "刷新超级大脑",
          "启动超级大脑"
        ],
        [
          "不回复",
          "没反应",
          "不在",
          "断了",
          "坏了",
          "失灵",
          "fault",
          "broken",
          "not working"
        ],
        [
          "GitHub",
          "公开版",
          "分享包",
          "release",
          "zip",
          "上传",
          "发布"
        ],
        [
          "还记得",
          "上次",
          "之前",
          "另一个会话",
          "继续",
          "remember",
          "previous",
          "resume",
          "continue"
        ],
        [
          "大脑",
          "脑子",
          "G1",
          "方向",
          "目标",
          "这个项目"
        ]
      ]
    },
    "confidence": {
      "inject": 0.6,
      "summaryOnly": 0.2
    },
    "recency": {
      "enabled": true,
      "halfLifeDays": 14,
      "maxBoost": 0.22,
      "sessionBoost": 0.12,
      "taskBoost": 0.1,
      "profileIntentBoost": 0.12,
      "experienceIntentBoost": 0.08,
      "personaIntentBoost": 0.08,
      "recentSourceBoost": 0.08,
      "currentSourceBoost": 0.05
    },
    "hybrid": {
      "enabled": true,
      "sourceWeights": {
        "sandglass": 0.55,
        "graph": 0.7,
        "state": 0.75,
        "sessionBinding": 0.78,
        "recent": 0.35,
        "persona": 0.62
      },
      "boosts": {
        "summary": 0.12,
        "current": 0.1,
        "verified": 0.08,
        "adr": 0.08,
        "decision": 0.06,
        "exactQuery": 0.15,
        "termMatch": 0.04,
        "profile": 0.08,
        "session": 0.06,
        "task": 0.05,
        "experience": 0.07,
        "persona": 0.09
      },
      "penalties": {
        "negativeFeedback": 0.22,
        "stale": 0.3,
        "expired": 0.35,
        "untagged": 0.05
      },
      "sources": [
        "sandglass",
        "graph",
        "state",
        "recent",
        "persona"
      ],
      "fallbackRecentWhenBelowTopK": true,
      "stateTriggers": [
        "当前",
        "状态",
        "版本",
        "进度",
        "改到哪",
        "super-memory-brain",
        "baseline",
        "changelog",
        "manifest"
      ],
      "profileIntentTriggers": [
        "你觉得我是什么样的人",
        "我是什么样的人",
        "我的性格",
        "我的偏好",
        "按我的习惯来",
        "你还记得我吗",
        "还记得我",
        "我的经历",
        "我的风格",
        "我的习惯"
      ],
      "experienceIntentTriggers": [
        "我的经历",
        "之前踩过的坑",
        "以前怎么做",
        "按之前经验",
        "经验",
        "教训",
