{
  "version": "0.5.80",
  "memoryShortcut": "memory:auto；G1 governs, ORC routes, Sandglass hybrid recall only on semantic/keyword recall; stable state only; private memory requires confirmation and [PRIVACY].",
  "memoryModes": [
    "auto",
    "force",
    "off"
  ],
  "provenanceRequired": [
    "platform",
    "agent",
    "sessionId",
    "taskId",
    "workspaceKey",
    "timestamp",
    "status",
    "source",
    "evidence"
  ],
  "checkpointLifecycle": {
    "preExecution": "write active checkpoint before long-running or pre-approved tasks with platform, agent, session/task code, timestamp, current step, and blockers",
    "minimumAutoCheckpointSteps": 3,
    "requireApprovedPlan": true,
    "completion": "automatically complete only the matching active checkpoint after successful verification; failed or missing verification leaves it active"
  },
  "executionContract": {
    "priority": ["visible conversation tail", "current task execution contract", "phase checkpoint", "governed memory"],
    "latestOnlyPerTask": true,
    "maxAgeHours": 168,
    "rawTranscriptAllowed": false,
    "newUserInstructionRequiresReconciliation": true,
    "unknownOrConflictPolicy": "do not infer the latest action; require confirmation before mutation",
    "invalidatedWorkGuard": true,
    "midTaskInstructionPolicy": {
      "defaultMode": "side_branch",
      "modes": ["continue", "side_branch", "replace"],
      "parentReturnStack": true,
      "maxDepth": 4,
      "rawTranscriptStored": false,
      "resumeCommand": "execution-contract.ps1 -Action ResumeParent",
      "replaceRequiresExplicitIntent": true
    }
  },
  "taskIdentityIndex": {
    "identityMode": "composite-key-upsert",
    "workspaceIsolation": "automatic continuation requires a matching workspaceKey; legacy or foreign checkpoints require explicit selection",
    "maxSessionTaskLinks": 256,
    "maxTaskMemoryLinks": 512,
    "completedRetentionDays": 120
  },
  "preflight": {
    "enabled": true,
    "triggerBeforeCodeChange": true,
    "defaultSilent": true,
    "acceptedConstraintTags": [
      "[CURRENT]",
      "[VERIFIED]",
      "[DECISION]",
      "[ADR]",
      "[TASK]"
    ],
    "acceptedAdrStatuses": [
      "accepted"
    ],
    "maxConstraints": 6,
    "maxClaimChars": 160,
    "guardFailOnConflict": true,
    "writeLastPreflight": true
  },
  "engineeringJudgment": {
    "enabled": true,
    "activation": ["debug", "repair", "optimization", "architecture", "migration", "performance", "root-cause analysis", "consequential option selection", "best or optimal claim"],
    "directPathExclusions": ["greeting", "acknowledgement", "simple factual answer", "tiny fully specified low-risk action"],
    "epistemicClasses": ["FACT", "INFERENCE", "UNKNOWN"],
    "factPolicy": "A FACT requires named current evidence; current live evidence overrides memory, summaries, and assumptions.",
    "rootCauseStatuses": ["verified", "hypothesis", "unknown"],
    "criticalUnknownPolicy": "Use the cheapest discriminating test before causal certainty or a decision-changing claim.",
    "optimalityRequirements": ["objective", "constraints", "at least two feasible options", "tradeoffs", "criteria", "evidence-backed facts", "resolution evidence for decision-changing unknowns"],
    "executionStepRequirements": ["input", "output", "acceptance", "stopCondition"],
    "outputContract": ["Judgment", "Evidence", "Best option", "Execution chain", "Acceptance/Risk"],
    "decisionGate": "scripts/engineering-decision-gate.ps1",
    "interventionPolicy": {
      "threshold": "intervene only when expected benefit is material or risk is material/high",
      "minorOptimizationBehavior": "silent",
      "materialBenefitMinimumEvidence": "inference",
      "materialRiskMinimumEvidence": "inference",
      "highRiskWithoutEvidence": "intervene only to verify or contain the risk; do not assert it as fact",
      "outputFields": ["evidence", "expectedDelta", "risk", "recommendation"]
    }
  },
  "requiredTags": [
    "[CURRENT]",
    "[VERIFIED]",
    "[HISTORY]",
    "[STALE]",
    "[BLOCKER]",
    "[KNOWN_LIMITATION]",
    "[PRIVACY]",
    "[DECISION]",
    "[ADR]",
