    "mustContain": ["memory-eval.ps1", "last-memory-eval.json", "passRate"]
  },
  {
    "question": "检索默认 top_k 和 max_tokens 哪里配置？",
    "sources": ["memory-policy.json", "scripts/recall-search.ps1"],
    "mustContain": ["top_k", "max_tokens", "TopK", "MaxTokens"]
  },
  {
    "question": "摘要优先检索怎么启用？",
    "sources": ["memory-policy.json", "scripts/recall-search.ps1"],
    "mustContain": ["summaryFirst", "[SUMMARY]"]
