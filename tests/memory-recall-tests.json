  {
    "question": "临时会话绑定如何防止记忆幻想？",
    "sources": ["super-memory-brain/SKILL.md", "scripts/session-binding.ps1", "scripts/recall-search.ps1", "scripts/doctor.ps1"],
    "mustContain": ["session-binding.json", "noRawChat", "temporary_session_binding", "session_binding_expired"]
  },
  {
    "question": "结构化改动前应该怎么说明原因和验证？",
    "sources": ["scripts/causal-change-plan.ps1", "super-memory-brain/SKILL.md", "README.md"],
    "mustContain": ["causal-change-plan.ps1", "RootCause", "ExpectedOptimization", "VerificationMethod", "residual risk"]
  }
